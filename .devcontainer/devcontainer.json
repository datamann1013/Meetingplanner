{
  "name": "Meetingplanner",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceFolder": "/workspaces/Meetingplanner",
  "runArgs": [
    "--userns=keep-id",
    "--security-opt",
    "label=disable"
  ],
  "forwardPorts": [8000, 5173, 5432],
  "portsAttributes": {
    "8000": { "label": "FastAPI backend" },
    "5173": { "label": "Vue frontend" },
    "5432": { "label": "PostgreSQL" }
  },
  "postCreateCommand": "bash /workspaces/Meetingplanner/.devcontainer/setup.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "Vue.volar",
        "ms-python.python",
        "ms-python.vscode-pylance",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/workspaces/Meetingplanner/backend/venv/bin/python"
      }
    }
  },
  "remoteUser": "node"
}
