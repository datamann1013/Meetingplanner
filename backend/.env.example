# Copy this file to .env and fill in your values before running.

# Database
DATABASE_URL=postgresql+asyncpg://meetingplanner:devpassword@localhost:5432/meetingplanner

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=168

# File storage ("local" or "s3")
STORAGE_TYPE=local
STORAGE_PATH=./uploads

# CORS — comma-separated origins the browser is allowed to call from
CORS_ORIGINS=http://localhost:5173

# Email (leave blank to disable; required for Phase 4)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@yourorchestra.com

# Redis / Celery (required for Phase 4 email jobs)
REDIS_URL=redis://localhost:6379/0

# Seed script — credentials for the first SuperAdmin account
SEED_ADMIN_EMAIL=admin@yourorchestra.com
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=changeme123
